# Oracle Database
ORACLE_HOST=oracle-db
ORACLE_PORT=1521
ORACLE_SERVICE=FREE
ORACLE_USER=demo
ORACLE_PASSWORD=DemoPass1
ORACLE_SYSTEM_PASSWORD=OraclePass1
ORACLE_POOL_MIN=2
ORACLE_POOL_MAX=10
ORACLE_POOL_INCREMENT=1

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=oracle-otel-showcase
OTEL_SERVICE_VERSION=1.0.0

# Workload simulation
WORKLOAD_INTERVAL_SECONDS=2.0
VECTOR_DIMENSIONS=1536
VECTOR_COUNT_SEED=100

# Report generator
PROMETHEUS_URL=http://prometheus:9090
TEMPO_URL=http://tempo:3200
REPORT_OUTPUT_DIR=/reports
REPORT_LOOKBACK_MINUTES=30
